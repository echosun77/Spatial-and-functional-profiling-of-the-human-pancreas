OUTPUT_DIR = Path("/path/to/output/")
OUTPUT_DIR.mkdir(exist_ok=True)

PIXEL_UM      = 0.1235   # um per pixel (20x LSM980)
TILE_SIZE     = 4000     # pixels per tile
OVERLAP       = 400      # tile overlap pixels
CELL_DIAM     = 100      # Cellpose diameter (pixels)
